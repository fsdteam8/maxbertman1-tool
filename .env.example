# --- Invoice Automation Configuration ---

# 1. API Security / Attachment Limits
MAX_ATTACHMENT_BYTES=20971520 # 20MB
MAX_ATTACHMENTS=3
ALLOWED_SENDERS=staff@yourdomain.com,admin@yourdomain.com

# 2. SMTP Configuration (for Outbound Emails)
# Used to send the processed invoice back to the staff member
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Invoice Automation" <your-email@gmail.com>

# 3. Next.js Base URL (for links in failure emails)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Note: For inbound email automation, you must point your 
# SendGrid Inbound Parse (or similar) webhook to:
# https://your-deployed-domain.com/api/email/inbound

